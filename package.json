{
  "name": "logsight",
  "version": "1.0.0",
  "description": "Production-style System Monitoring & Alerting Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm run dev",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrishali34/logsight.git"
  },
  "keywords": [
    "monitoring",
    "alerting",
    "logging",
    "observability"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vrishali34/logsight/issues"
  },
  "homepage": "https://github.com/vrishali34/logsight#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "node-pg-migrate": {
    "databaseUrl": "DATABASE_URL",
    "migrationsTable": "pgmigrations",
    "dir": "migrations"
  }
}
