{
  "name": "logsight",
  "version": "1.0.0",
  "description": "Production-style System Monitoring & Alerting Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrishali34/logsight.git"
  },
  "keywords": ["monitoring", "alerting", "logging", "observability"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vrishali34/logsight/issues"
  },
  "homepage": "https://github.com/vrishali34/logsight#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.9.1",
    "nodemon": "^3.1.14"
  },
  "node-pg-migrate": {
    "databaseUrl": "DATABASE_URL",
    "migrationsTable": "pgmigrations",
    "dir": "migrations"
  }
}